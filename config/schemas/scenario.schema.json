{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scenario Configuration Schema",
  "description": "Schema for scenario generator tactical/geospatial configuration files",
  "type": "object",

  "required": [
    "scenario_meta",
    "targets",
    "threat_profiles",
    "sensor_network",
    "terrain_elevation_anchors"
  ],

  "properties": {

    "scenario_meta": {
      "type": "object",
      "required": [
        "name",
        "start_time_iso",
        "duration_seconds",
        "time_step_seconds"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "start_time_iso": {
          "type": "string",
          "format": "date-time"
        },
        "duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "time_step_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },

    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/location"
      }
    },

    "threat_profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "count",
          "speed_kmh",
          "alt_m",
          "classification",
          "launch_delay_sec",
          "id_suffix",
          "wkt_linestring"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "speed_kmh": {
            "type": "number",
            "minimum": 0
          },
          "alt_m": {
            "type": "number",
            "minimum": 0
          },
          "classification": {
            "type": "string"
          },
          "launch_delay_sec": {
            "type": "number",
            "minimum": 0
          },
          "id_suffix": {
            "type": "string"
          },
          "wkt_linestring": {
            "type": "string",
            "pattern": "^LINESTRING\\s*\\("
          }
        }
      }
    },

    "sensor_network": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "lat",
          "lon",
          "range_m",
          "update_rate_sec"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lon": {
            "type": "number"
          },
          "range_m": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "update_rate_sec": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },

    "terrain_elevation_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "lat",
          "lon",
          "elevation_msl"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lon": {
            "type": "number"
          },
          "elevation_msl": {
            "type": "number"
          }
        }
      }
    }

  },

  "$defs": {

    "location": {
      "type": "object",
      "required": [
        "lat",
        "lon",
        "alt"
      ],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "alt": {
          "type": "number"
        }
      }
    }

  }
}